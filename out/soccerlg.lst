    00000000                        374 _CallSpriteFrame::
                                    375 ;./soccerlg.c:124: __endasm;
    00000000 47               [ 4]  376 	ld	b,a ; b = x , de = y
    00000001 F1               [10]  377 	pop	af ; pop return
    00000002 E1               [10]  378 	pop	hl ; hl = frame
    00000003 F5               [11]  379 	push	af ; push return
    00000004 7D               [ 4]  380 	ld	a,l
    00000005 E6 03            [ 7]  381 	and	#3
    00000007 87               [ 4]  382 	add	a,a
    00000008 87               [ 4]  383 	add	a,a
    00000009 4F               [ 4]  384 	ld	c,a ; in c the low address of the function to be called
    0000000A CB 3C            [ 8]  385 	srl	h ; page = 100 + frame / 4
    0000000C CB 1D            [ 8]  386 	rr	l
    0000000E CB 3C            [ 8]  387 	srl	h
    00000010 CB 1D            [ 8]  388 	rr	l
    00000012 3E 64            [ 7]  389 	ld	a,#100
    00000014 85               [ 4]  390 	add	a,l ; segments in the current offset (!)
    00000015 32 00 B0         [13]  391 	ld	(#0xB000),a
    00000018 32r06r00         [13]  392 	ld	(#(_g_Bank0Segment + 6) + 0),a ; prevent future possible issues on the ISR
    0000001B 62               [ 4]  393 	ld	h,d ; HLB = y*256+X = 2 * VRAM_address
    0000001C 6B               [ 4]  394 	ld	l,e
    0000001D 29               [11]  395 	add	hl,hl ; in h 3 bit di indirizzo per R14
    0000001E 7C               [ 4]  396 	ld	a,h
    0000001F E6 01            [ 7]  397 	and	#1
    00000021 FD                     398 	.db	#0xFD
    00000022 6F               [ 4]  399 	ld	l,a ;ld iyl,a ; save R14 in iyl
    00000023 7C               [ 4]  400 	ld	a,h
    00000024 E6 06            [ 7]  401 	and	#6
    00000026 FD                     402 	.db	#0xFD
    00000027 67               [ 4]  403 	ld	h,a ;ld iyh,a ; save vram page in iyh
    00000028 CB 3A            [ 8]  404 	srl	d
    0000002A CB 1B            [ 8]  405 	rr	e
    0000002C CB 38            [ 8]  406 	srl	b
    0000002E 53               [ 4]  407 	ld	d,e
    0000002F 58               [ 4]  408 	ld	e,b ; DE = (x + y*256)/2 & 0xFFFF
    00000030 69               [ 4]  409 	ld	l,c
    00000031 26 A0            [ 7]  410 	ld	h,#0xA0
    00000033 E9               [ 4]  411 	jp	(hl)
